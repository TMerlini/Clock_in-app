# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Google Calendar API
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=your_google_api_key

# Stripe webhook (for plan and call pack fulfillment)
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SECRET_KEY=sk_live_...

# Warnings push cron (Vercel serverless)
CRON_SECRET=your_cron_secret_for_cron_auth
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
PROGRESSIER_API_KEY=your_progressier_api_key
PROGRESSIER_API_ENDPOINT=https://... # From Progressier Dashboard > API Docs > Send notifications
