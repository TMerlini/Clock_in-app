{
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/cron/warnings-push",
      "schedule": "*/15 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/((?!api|images|privacy|terms|robots\\.txt|sitemap\\.xml|vite\\.svg).*)", "destination": "/index.html" }
  ]
}
